<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SHORTA Admin</title>

  <style>
    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #f7f7f8;
      color: #111111;
    }

    .page {
      max-width: 1400px;
      margin: 0 auto;
      padding: 24px;
    }

    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 24px;
      flex-wrap: wrap;
    }

    .brand {
      font-size: 34px;
      font-weight: 800;
      letter-spacing: 1px;
    }

    .topbar-right {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      align-items: center;
    }

    .refresh-btn {
      border: none;
      background: #111111;
      color: #ffffff;
      border-radius: 12px;
      padding: 12px 18px;
      font-size: 15px;
      font-weight: 700;
      cursor: pointer;
    }

    .search-input {
      width: 320px;
      max-width: 100%;
      border: 1px solid #d1d5db;
      border-radius: 12px;
      padding: 12px 14px;
      font-size: 15px;
      background: #ffffff;
    }

    .kpis {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 16px;
      margin-bottom: 24px;
    }

    .kpi-card {
      background: #ffffff;
      border: 1px solid #e5e7eb;
      border-radius: 18px;
      padding: 18px;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.04);
    }

    .kpi-label {
      font-size: 14px;
      color: #6b7280;
      margin-bottom: 10px;
    }

    .kpi-value {
      font-size: 30px;
      font-weight: 800;
      line-height: 1;
    }

    .panel {
      background: #ffffff;
      border: 1px solid #e5e7eb;
      border-radius: 20px;
      padding: 18px;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.04);
    }

    .panel-title {
      font-size: 20px;
      font-weight: 800;
      margin: 0 0 16px 0;
    }

    .status-bar {
      min-height: 22px;
      font-size: 14px;
      color: #374151;
      margin-bottom: 16px;
    }

    .error-box {
      display: none;
      background: #fff4f4;
      border: 1px solid #f1b5b5;
      color: #8a1f1f;
      border-radius: 14px;
      padding: 14px;
      margin-bottom: 16px;
      white-space: pre-wrap;
      word-break: break-word;
      font-size: 14px;
    }

    .salons-list {
      display: grid;
      gap: 16px;
    }

    .salon-card {
      border: 1px solid #ececec;
      border-radius: 18px;
      padding: 18px;
      background: #ffffff;
    }

    .salon-top {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 18px;
      flex-wrap: wrap;
    }

    .salon-main {
      flex: 1 1 420px;
      min-width: 280px;
    }

    .salon-name {
      font-size: 22px;
      font-weight: 800;
      margin-bottom: 6px;
    }

    .salon-meta {
      font-size: 14px;
      color: #6b7280;
      line-height: 1.6;
    }

    .badges {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-top: 10px;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 999px;
      padding: 7px 12px;
      font-size: 13px;
      font-weight: 700;
    }

    .badge-trial {
      background: #fff7ed;
      color: #9a3412;
    }

    .badge-active {
      background: #ecfdf5;
      color: #166534;
    }

    .badge-suspended {
      background: #fef2f2;
      color: #991b1b;
    }

    .badge-default {
      background: #f3f4f6;
      color: #374151;
    }

    .salon-stats {
      display: grid;
      grid-template-columns: repeat(4, minmax(120px, 1fr));
      gap: 12px;
      width: 100%;
      max-width: 520px;
    }

    .mini-stat {
      background: #f9fafb;
      border: 1px solid #eceff3;
      border-radius: 14px;
      padding: 12px;
      text-align: center;
    }

    .mini-stat-label {
      font-size: 12px;
      color: #6b7280;
      margin-bottom: 6px;
    }

    .mini-stat-value {
      font-size: 22px;
      font-weight: 800;
    }

    .salon-actions {
      margin-top: 16px;
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .action-btn {
      border: none;
      border-radius: 12px;
      padding: 11px 16px;
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
    }

    .btn-primary {
      background: #111111;
      color: #ffffff;
    }

    .btn-secondary {
      background: #f3f4f6;
      color: #111111;
    }

    .details {
      display: none;
      margin-top: 18px;
      padding-top: 18px;
      border-top: 1px solid #ececec;
    }

    .details-grid {
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: 18px;
    }

    .detail-box {
      background: #fafafa;
      border: 1px solid #ececec;
      border-radius: 16px;
      padding: 16px;
    }

    .detail-title {
      font-size: 16px;
      font-weight: 800;
      margin-bottom: 12px;
    }

    .detail-line {
      font-size: 14px;
      line-height: 1.7;
      color: #222222;
      word-break: break-word;
    }

    .detail-line strong {
      color: #111111;
    }

    .device-item,
    .event-item {
      border-top: 1px solid #ececec;
      padding: 10px 0;
      font-size: 14px;
      line-height: 1.5;
    }

    .device-item:first-child,
    .event-item:first-child {
      border-top: none;
      padding-top: 0;
    }

    .muted {
      color: #6b7280;
    }

    .empty-state {
      text-align: center;
      padding: 36px 12px;
      color: #6b7280;
      font-size: 15px;
    }

    .link-box {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-top: 10px;
    }

    .link-input {
      flex: 1 1 420px;
      min-width: 240px;
      border: 1px solid #d1d5db;
      border-radius: 12px;
      padding: 10px 12px;
      font-size: 14px;
      background: #ffffff;
    }

    @media (max-width: 1100px) {
      .kpis {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .details-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 760px) {
      .kpis {
        grid-template-columns: 1fr;
      }

      .salon-stats {
        grid-template-columns: repeat(2, minmax(0, 1fr));
        max-width: none;
      }

      .brand {
        font-size: 28px;
      }
    }
  </style>
</head>
<body>
  <div class="page">
    <div class="topbar">
      <div class="brand">SHORTA Admin</div>

      <div class="topbar-right">
        <input
          id="searchInput"
          class="search-input"
          type="text"
          placeholder="Rechercher un salon, une ville, un code..."
        />
        <button id="refreshBtn" class="refresh-btn">Rafraîchir</button>
      </div>
    </div>

    <div class="kpis">
      <div class="kpi-card">
        <div class="kpi-label">Salons</div>
        <div id="kpiSalons" class="kpi-value">0</div>
      </div>

      <div class="kpi-card">
        <div class="kpi-label">Salons actifs</div>
        <div id="kpiActiveSalons" class="kpi-value">0</div>
      </div>

      <div class="kpi-card">
        <div class="kpi-label">Devices</div>
        <div id="kpiDevices" class="kpi-value">0</div>
      </div>

      <div class="kpi-card">
        <div class="kpi-label">Events</div>
        <div id="kpiEvents" class="kpi-value">0</div>
      </div>
    </div>

    <div class="panel">
      <h1 class="panel-title">Liste des salons</h1>

      <div id="status" class="status-bar"></div>
      <div id="errorBox" class="error-box"></div>

      <div id="salonsList" class="salons-list"></div>
    </div>
  </div>

  <script type="module">
    import { createClient } from 'https://esm.sh/@supabase/supabase-js@2'

    const SUPABASE_URL = 'https://ooqgocqdggxcgnzhxjil.supabase.co'
    const SUPABASE_ANON_KEY = 'sb_publishable_IXKLxFLH3kUhLiabQVsVKg_oXNC4jLu'
    const APP_BASE_URL = 'https://shorta-339p.vercel.app'

    const supabase = createClient(SUPABASE_URL, SUPABASE_ANON_KEY)

    const statusEl = document.getElementById('status')
    const errorBoxEl = document.getElementById('errorBox')
    const salonsListEl = document.getElementById('salonsList')
    const searchInputEl = document.getElementById('searchInput')
    const refreshBtnEl = document.getElementById('refreshBtn')

    const kpiSalonsEl = document.getElementById('kpiSalons')
    const kpiActiveSalonsEl = document.getElementById('kpiActiveSalons')
    const kpiDevicesEl = document.getElementById('kpiDevices')
    const kpiEventsEl = document.getElementById('kpiEvents')

    let allSalons = []

    function setStatus(message) {
      statusEl.textContent = message
    }

    function showError(message) {
      errorBoxEl.style.display = 'block'
      errorBoxEl.textContent = message
      console.error(message)
    }

    function hideError() {
      errorBoxEl.style.display = 'none'
      errorBoxEl.textContent = ''
    }

    function getSubscriptionBadgeClass(value) {
      const normalized = String(value || '').toLowerCase()

      if (normalized === 'trial') return 'badge badge-trial'
      if (normalized === 'active') return 'badge badge-active'
      if (normalized === 'suspended') return 'badge badge-suspended'

      return 'badge badge-default'
    }

    function formatDate(value) {
      if (!value) return '—'
      return new Date(value).toLocaleString('fr-FR')
    }

    function safeText(value) {
      if (value === null || value === undefined || value === '') return '—'
      return String(value)
    }

    function updateKpis(salons) {
      const salonsCount = salons.length
      const activeSalonsCount = salons.filter(s => s.is_active).length
      const devicesCount = salons.reduce((sum, s) => sum + Number(s.devices_count || 0), 0)
      const eventsCount = salons.reduce((sum, s) => sum + Number(s.events_count || 0), 0)

      kpiSalonsEl.textContent = salonsCount
      kpiActiveSalonsEl.textContent = activeSalonsCount
      kpiDevicesEl.textContent = devicesCount
      kpiEventsEl.textContent = eventsCount
    }

    function getFilteredSalons() {
      const q = searchInputEl.value.trim().toLowerCase()

      if (!q) return allSalons

      return allSalons.filter((salon) => {
        const haystack = [
          salon.name,
          salon.city,
          salon.salon_code,
          salon.slug,
          salon.subscription_status,
          salon.google_business_name,
          salon.email,
          salon.phone
        ]
          .filter(Boolean)
          .join(' ')
          .toLowerCase()

        return haystack.includes(q)
      })
    }

    function renderSalons() {
      const salons = getFilteredSalons()
      updateKpis(salons)

      if (!salons.length) {
        salonsListEl.innerHTML = '<div class="empty-state">Aucun salon trouvé.</div>'
        return
      }

      salonsListEl.innerHTML = salons.map((salon) => {
        return `
          <div class="salon-card" id="salon-card-${salon.salon_id}">
            <div class="salon-top">
              <div class="salon-main">
                <div class="salon-name">${safeText(salon.name)}</div>
                <div class="salon-meta">
                  <strong>Code salon :</strong> ${safeText(salon.salon_code)}<br />
                  <strong>Slug :</strong> ${safeText(salon.slug)}<br />
                  <strong>Ville :</strong> ${safeText(salon.city)}<br />
                  <strong>Email :</strong> ${safeText(salon.email)}<br />
                  <strong>Téléphone :</strong> ${safeText(salon.phone)}
                </div>

                <div class="badges">
                  <span class="${getSubscriptionBadgeClass(salon.subscription_status)}">
                    ${safeText(salon.subscription_status)}
                  </span>

                  <span class="badge ${salon.is_active ? 'badge-active' : 'badge-suspended'}">
                    ${salon.is_active ? 'Actif' : 'Inactif'}
                  </span>
                </div>
              </div>

              <div class="salon-stats">
                <div class="mini-stat">
                  <div class="mini-stat-label">Avis Google</div>
                  <div class="mini-stat-value">${safeText(salon.latest_review_count ?? salon.google_review_count ?? 0)}</div>
                </div>

                <div class="mini-stat">
                  <div class="mini-stat-label">Note</div>
                  <div class="mini-stat-value">${safeText(salon.latest_review_rating ?? '—')}</div>
                </div>

                <div class="mini-stat">
                  <div class="mini-stat-label">Devices</div>
                  <div class="mini-stat-value">${safeText(salon.devices_count ?? 0)}</div>
                </div>

                <div class="mini-stat">
                  <div class="mini-stat-label">Events</div>
                  <div class="mini-stat-value">${safeText(salon.events_count ?? 0)}</div>
                </div>
              </div>
            </div>

            <div class="salon-actions">
              <button class="action-btn btn-primary" data-action="toggle-details" data-salon-id="${salon.salon_id}">
                Voir détails
              </button>
            </div>

            <div class="details" id="details-${salon.salon_id}">
              <div class="details-grid">
                <div class="detail-box">
                  <div class="detail-title">Informations salon</div>

                  <div class="detail-line"><strong>Nom :</strong> ${safeText(salon.name)}</div>
                  <div class="detail-line"><strong>Ville :</strong> ${safeText(salon.city)}</div>
                  <div class="detail-line"><strong>Adresse :</strong> ${safeText(salon.address)}</div>
                  <div class="detail-line"><strong>Email :</strong> ${safeText(salon.email)}</div>
                  <div class="detail-line"><strong>Téléphone :</strong> ${safeText(salon.phone)}</div>
                  <div class="detail-line"><strong>Google Business :</strong> ${safeText(salon.google_business_name)}</div>
                  <div class="detail-line"><strong>Lien Google Maps :</strong> ${safeText(salon.google_maps_url)}</div>
                  <div class="detail-line"><strong>Lien Google avis :</strong> ${safeText(salon.google_review_url)}</div>
                  <div class="detail-line"><strong>Dernier snapshot avis :</strong> ${formatDate(salon.latest_review_captured_at)}</div>
                  <div class="detail-line"><strong>Créé le :</strong> ${formatDate(salon.created_at)}</div>
                  <div class="detail-line"><strong>Notes :</strong> ${safeText(salon.notes)}</div>

                  <div class="link-box" id="kiosk-link-box-${salon.salon_id}">
                    <input class="link-input" readonly value="Chargement du lien borne..." />
                  </div>
                </div>

                <div class="detail-box">
                  <div class="detail-title">Devices</div>
                  <div id="devices-${salon.salon_id}" class="muted">Chargement...</div>
                </div>
              </div>

              <div class="detail-box" style="margin-top: 18px;">
                <div class="detail-title">Derniers events</div>
                <div id="events-${salon.salon_id}" class="muted">Chargement...</div>
              </div>
            </div>
          </div>
        `
      }).join('')

      attachCardActions()
    }

    async function loadDashboard() {
      try {
        hideError()
        setStatus('Chargement des salons...')

        const { data, error } = await supabase
          .from('salon_dashboard_summary')
          .select('*')
          .order('created_at', { ascending: false })

        if (error) {
          throw new Error(error.message)
        }

        allSalons = data || []

        renderSalons()
        setStatus(allSalons.length + ' salon(s) chargé(s).')
      } catch (error) {
        setStatus('Erreur')
        showError('Erreur chargement dashboard : ' + error.message)
      }
    }

    async function loadSalonDetails(salonId, salonCode) {
      const devicesContainer = document.getElementById('devices-' + salonId)
      const eventsContainer = document.getElementById('events-' + salonId)
      const kioskLinkBox = document.getElementById('kiosk-link-box-' + salonId)

      devicesContainer.textContent = 'Chargement...'
      eventsContainer.textContent = 'Chargement...'

      try {
        const { data: devices, error: devicesError } = await supabase
          .from('devices')
          .select('id, device_code, label, is_active, created_at')
          .eq('salon_id', salonId)
          .order('created_at', { ascending: false })

        if (devicesError) {
          throw new Error(devicesError.message)
        }

        const { data: events, error: eventsError } = await supabase
          .from('events')
          .select('id, event_type, event_value, payload, created_at, device_id')
          .eq('salon_id', salonId)
          .order('created_at', { ascending: false })
          .limit(20)

        if (eventsError) {
          throw new Error(eventsError.message)
        }

        if (!devices || !devices.length) {
          devicesContainer.innerHTML = '<div class="muted">Aucun device.</div>'
          kioskLinkBox.innerHTML = '<input class="link-input" readonly value="Aucun device configuré" />'
        } else {
          devicesContainer.innerHTML = devices.map((device) => {
            return `
              <div class="device-item">
                <strong>${safeText(device.label)}</strong><br />
                Code : ${safeText(device.device_code)}<br />
                Statut : ${device.is_active ? 'Actif' : 'Inactif'}<br />
                Créé le : ${formatDate(device.created_at)}
              </div>
            `
          }).join('')

          const firstDevice = devices[0]
          const kioskUrl = APP_BASE_URL + '/kiosk/' + encodeURIComponent(salonCode) + '/' + encodeURIComponent(firstDevice.device_code)

          kioskLinkBox.innerHTML = `
            <input class="link-input" readonly value="${kioskUrl}" />
            <button class="action-btn btn-secondary" data-copy="${kioskUrl}">Copier le lien borne</button>
          `
        }

        if (!events || !events.length) {
          eventsContainer.innerHTML = '<div class="muted">Aucun event.</div>'
        } else {
          const deviceMap = {}
          devices.forEach((device) => {
            deviceMap[device.id] = device.device_code
          })

          eventsContainer.innerHTML = events.map((event) => {
            return `
              <div class="event-item">
                <strong>${safeText(event.event_type)}</strong> — ${safeText(event.event_value)}<br />
                Device : ${safeText(deviceMap[event.device_id] || '—')}<br />
                Date : ${formatDate(event.created_at)}
              </div>
            `
          }).join('')
        }

        attachCopyButtons()
      } catch (error) {
        devicesContainer.innerHTML = '<div class="muted">Erreur devices : ' + error.message + '</div>'
        eventsContainer.innerHTML = '<div class="muted">Erreur events : ' + error.message + '</div>'
      }
    }

    function attachCopyButtons() {
      const copyButtons = document.querySelectorAll('[data-copy]')

      copyButtons.forEach((button) => {
        button.addEventListener('click', async () => {
          const text = button.getAttribute('data-copy') || ''

          try {
            await navigator.clipboard.writeText(text)
            button.textContent = 'Lien copié'
            setTimeout(() => {
              button.textContent = 'Copier le lien borne'
            }, 1200)
          } catch (error) {
            alert('Impossible de copier automatiquement. Voici le lien :\n\n' + text)
          }
        })
      })
    }

    function attachCardActions() {
      const toggleButtons = document.querySelectorAll('[data-action="toggle-details"]')

      toggleButtons.forEach((button) => {
        button.addEventListener('click', async () => {
          const salonId = button.getAttribute('data-salon-id')
          const detailsEl = document.getElementById('details-' + salonId)
          const salon = allSalons.find((s) => s.salon_id === salonId)

          if (!detailsEl || !salon) return

          const isOpen = detailsEl.style.display === 'block'

          if (isOpen) {
            detailsEl.style.display = 'none'
            button.textContent = 'Voir détails'
            return
          }

          detailsEl.style.display = 'block'
          button.textContent = 'Masquer détails'

          await loadSalonDetails(salon.salon_id, salon.salon_code)
        })
      })
    }

    searchInputEl.addEventListener('input', renderSalons)
    refreshBtnEl.addEventListener('click', loadDashboard)

    loadDashboard()
  </script>
</body>
</html>
